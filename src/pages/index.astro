---
import SocialList from "@/components/SocialList.astro";
import Meteors from "@/components/Meteors.astro";
import LandingLayout from "@/layouts/Landing.astro";
---

<LandingLayout meta={{ title: "Portfolio" }}>
	<!-- ═══════════════════════════════════════════════ -->
	<!-- HERO — Pantalla completa                       -->
	<!-- ═══════════════════════════════════════════════ -->
	<section
		class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-4 text-center"
		id="hero"
	>
		<!-- Fondo de Meteoritos estilo Magic UI -->
		<Meteors number={30} />

		<div class="relative z-10 max-w-2xl">
			<!-- Subtítulo con efecto de parpadeo escalonado y hover -->
			<p class="text-accent mb-3 text-sm font-semibold uppercase tracking-widest cursor-default group">
				<span class="inline-block animate-pulse hover:text-link hover:scale-105 transition-all">Administración de Sistemas</span>
				<span class="mx-1 opacity-50">·</span>
				<span class="inline-block animate-pulse hover:text-link hover:scale-105 transition-all" style="animation-delay: 0.3s">Redes</span>
				<span class="mx-1 opacity-50">·</span>
				<span class="inline-block animate-pulse hover:text-link hover:scale-105 transition-all" style="animation-delay: 0.6s">Seguridad</span>
			</p>
			
			<!-- Título con efecto de máquina de escribir y hover resplandeciente -->
			<h1 class="mb-6 text-4xl font-bold sm:text-5xl md:text-6xl min-h-[40px] sm:min-h-[60px]">
				<span 
					id="typewriter-name" 
					class="text-accent-2 inline-block cursor-default border-r-4 border-accent pr-2 hover-glow"
				></span>
			</h1>
			<p class="text-muted mx-auto mb-8 max-w-lg text-base leading-relaxed sm:text-lg">
				Técnico en ASIR. Construyo y documento infraestructuras de red seguras, despliegues
				con Docker y sistemas de monitorización.
			</p>
			<SocialList />
		</div>

		<!-- Flecha de scroll -->
		<a
			aria-label="Ir a la sección sobre mí"
			class="text-muted hover:text-accent absolute bottom-10 animate-bounce transition-colors"
			href="#sobre-mi"
		>
			<svg
				class="h-8 w-8"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
				viewBox="0 0 24 24"
			>
				<path d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</a>
	</section>

	<script is:inline>
		// Lógica del efecto Máquina de Escribir
		const runTypewriter = () => {
			const nameEl = document.getElementById('typewriter-name');
			if (!nameEl) return;
			
			// Evitar múltiples ejecuciones concurrentes al recargar la página con View Transitions
			if (nameEl.hasAttribute('data-typing')) return;
			nameEl.setAttribute('data-typing', 'true');
			
			const text = "Pablo Calderón";
			let i = 0;
			let isDeleting = false;
			nameEl.textContent = ""; // Limpiar texto al iniciar
			
			// Añadir clase de parpadeo del cursor
			nameEl.classList.add('animate-[blink_0.8s_step-end_infinite]');

			const type = () => {
				// Detener la ejecución si el elemento ya no existe (por si el usuario navega a otra página)
				if (!nameEl.isConnected) return;

				if (isDeleting) {
					// Borrando
					nameEl.textContent = text.substring(0, i - 1);
					i--;
				} else {
					// Escribiendo
					nameEl.textContent = text.substring(0, i + 1);
					i++;
				}

				// Velocidades base: 80ms escribir, 40ms borrar (más rápido)
				let typingSpeed = isDeleting ? 40 : 80;

				if (!isDeleting && i === text.length) {
					// Cuando termina de escribir, espera 8 segundos antes de empezar a borrar
					typingSpeed = 4000; 
					isDeleting = true;
				} else if (isDeleting && i === 0) {
					// Cuando termina de borrar, espera medio segundo antes de volver a escribir
					isDeleting = false;
					typingSpeed = 500;
				}

				setTimeout(type, typingSpeed);
			};

			// Retraso inicial antes de empezar
			setTimeout(type, 500); 
		};

		// Ejecutar al cargar (compatible con View Transitions)
		document.addEventListener('astro:page-load', runTypewriter);
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', runTypewriter);
		} else {
			runTypewriter();
		}
	</script>

	<!-- ═══════════════════════════════════════════════ -->
	<!-- SOBRE MÍ                                       -->
	<!-- ═══════════════════════════════════════════════ -->
	<section class="mx-auto max-w-3xl scroll-mt-32 px-4 py-24 sm:px-8" id="sobre-mi">
		<h2 class="title mb-8 text-xl reveal">Sobre mí</h2>
		<div class="prose prose-sm prose-cactus max-w-none reveal" style="transition-delay: 150ms;">
			<p>
				Estudiante de 2º curso del CFGS en <strong>Administración de Sistemas Informáticos
				en Red (ASIR)</strong>. Me apasiona la administración de sistemas, las redes y la
				ciberseguridad.
			</p>
			<p>Durante mi formación he trabajado con:</p>
			<div class="mt-4 grid gap-3 sm:grid-cols-2">
				<!-- Tarjeta 1 -->
				<div class="reveal border-accent/20 hover:border-accent rounded-md border p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(42,188,137,0.15)]" data-cursor="-pointer" style="transition-delay: 200ms;">
					<p class="text-accent mb-1 text-xs font-semibold uppercase">Redes & Seguridad</p>
					<p class="text-muted text-xs">pfSense · VLANs · NAT · Wazuh SIEM</p>
				</div>
				<!-- Tarjeta 2 -->
				<div class="reveal border-accent/20 hover:border-accent rounded-md border p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(42,188,137,0.15)]" data-cursor="-pointer" style="transition-delay: 300ms;">
					<p class="text-accent mb-1 text-xs font-semibold uppercase">Contenedores & Servers</p>
					<p class="text-muted text-xs">Docker · Docker Compose · Ubuntu Server</p>
				</div>
				<!-- Tarjeta 3 -->
				<div class="reveal border-accent/20 hover:border-accent rounded-md border p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(42,188,137,0.15)]" data-cursor="-pointer" style="transition-delay: 400ms;">
					<p class="text-accent mb-1 text-xs font-semibold uppercase">Virtualización</p>
					<p class="text-muted text-xs">VirtualBox · VMware</p>
				</div>
				<!-- Tarjeta 4 -->
				<div class="reveal border-accent/20 hover:border-accent rounded-md border p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(42,188,137,0.15)]" data-cursor="-pointer" style="transition-delay: 500ms;">
					<p class="text-accent mb-1 text-xs font-semibold uppercase">Documentación & Web</p>
					<p class="text-muted text-xs">LaTeX · Markdown · Astro · Git</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════ -->
	<!-- PROYECTOS                                      -->
	<!-- ═══════════════════════════════════════════════ -->
	<section class="mx-auto max-w-3xl scroll-mt-32 px-4 py-24 sm:px-8" id="proyectos">
		<h2 class="title mb-4 text-xl reveal">Proyectos</h2>
		<p class="text-muted mb-10 text-sm reveal" style="transition-delay: 150ms;">
			Proyectos realizados durante el CFGS de ASIR. Algunos incluyen documentación técnica
			detallada.
		</p>

		<div class="space-y-6">
			<!-- Proyecto: Portfolio -->
			<article
				class="glow-card reveal relative overflow-hidden border-accent/20 hover:border-accent group rounded-md border p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(42,188,137,0.15)] cursor-pointer"
				onclick="window.location.href='/guias/desarrollo-portfolio/'"
				data-cursor="-pointer"
				style="transition-delay: 300ms;"
			>
				<div class="glow-pointer pointer-events-none absolute -inset-px opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				<div class="relative z-10">
					<div class="mb-2 flex flex-wrap items-center gap-2">
					<h3 class="text-base font-semibold">
						<a class="cactus-link" href="/guias/desarrollo-portfolio/">
							🌐 Portfolio Personal
						</a>
					</h3>
					<span class="rounded-full bg-yellow-500/10 px-2 py-0.5 text-xs font-medium text-yellow-500">
						En desarrollo
					</span>
				</div>
				<p class="text-muted mb-3 text-sm">
					Este sitio web. Construido con Astro (Cactus + Starlight), desplegado en GitHub Pages.
				</p>
				<div class="flex flex-wrap gap-1.5">
					{["Astro", "Starlight", "Tailwind CSS", "GitHub Pages"].map((tag) => (
						<span class="bg-accent/10 text-accent rounded-md px-2 py-0.5 text-xs">{tag}</span>
					))}
				</div>
				</div>
			</article>

			<!-- Placeholder para futuros proyectos -->
			<div class="reveal border-muted/20 text-muted rounded-md border border-dashed p-5 text-center text-sm" style="transition-delay: 400ms;">
				Más proyectos próximamente...
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════ -->
	<!-- CONTACTO / CTA                                 -->
	<!-- ═══════════════════════════════════════════════ -->
	<section class="mx-auto max-w-3xl scroll-mt-32 px-4 py-24 sm:px-8" id="contacto">
		<h2 class="title mb-6 text-xl">Contacto</h2>
		<p class="text-muted mb-6 text-sm">
			¿Quieres saber más o colaborar? Encuéntrame en:
		</p>
		<SocialList />
	</section>

	<style>
		@keyframes blink {
			0%, 100% { border-color: transparent; }
			50% { border-color: var(--color-accent); }
		}

		/* Efecto glow adaptativo según el tema (claro/oscuro) */
		.hover-glow {
			transition: filter 0.3s ease, transform 0.3s ease;
		}
		.hover-glow:hover {
			/* Sombra sutil de profundidad en modo claro */
			filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.15));
			transform: translateY(-4px);
		}
		:global([data-theme="dark"]) .hover-glow:hover {
			/* Resplandor claro e iluminado en modo oscuro */
			filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.25));
		}

		/* Animaciones de revelado (Native Intersection Observer) */
		.reveal {
			opacity: 0;
			transform: translateY(30px);
			transition: opacity 0.8s cubic-bezier(0.5, 0, 0, 1), transform 0.8s cubic-bezier(0.5, 0, 0, 1);
			will-change: opacity, transform;
		}
		.reveal.active {
			opacity: 1;
			transform: translateY(0);
		}

		/* Efecto Glow Dinámico siguiendo el ratón */
		.glow-pointer {
			background: radial-gradient(
				600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
				rgba(42, 188, 137, 0.1), /* Turquesa/Verde del tema Cactus */
				transparent 40%
			);
		}
	</style>

	<script is:inline>
		const setupInteractions = () => {
			// 1. Configurar Reveal Animations (Intersection Observer)
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');
					}
				});
			}, {
				threshold: 0.1, // Se dispara cuando el 10% del elemento es visible
				rootMargin: "0px 0px -50px 0px"
			});

			document.querySelectorAll('.reveal').forEach((el) => {
				observer.observe(el);
			});

			// 2. Configurar Glow Effect en tarjetas de proyectos
			const glowCards = document.querySelectorAll('.glow-card');
			glowCards.forEach((card) => {
				card.addEventListener('mousemove', (e) => {
					const rect = card.getBoundingClientRect();
					const x = e.clientX - rect.left;
					const y = e.clientY - rect.top;
					card.style.setProperty('--mouse-x', `${x}px`);
					card.style.setProperty('--mouse-y', `${y}px`);
				});
			});
		};

		// Ejecutar interacciones (Compatible con View Transitions)
		document.addEventListener('astro:page-load', setupInteractions);
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', setupInteractions);
		} else {
			setupInteractions();
		}
	</script>
</LandingLayout>
