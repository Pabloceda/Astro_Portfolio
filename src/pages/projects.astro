---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Proyectos destacados de Pablo Calderón — Administración de Sistemas, Redes y Seguridad",
	title: "Proyectos",
};

const projects = [
	{
		title: "🏗️ Infraestructura de Red Segura (TFG)",
		description:
			"Diseño e implementación de una infraestructura de red empresarial completa en entorno virtualizado. Incluye pfSense como firewall perimetral, segmentación con VLANs, DMZ para servicios expuestos, Docker para despliegue de aplicaciones y Wazuh como SIEM.",
		tags: ["pfSense", "Docker", "Wazuh", "VLANs", "Ubuntu Server"],
		link: "/tfg/arquitectura-red/",
		status: "En desarrollo",
	},
	{
		title: "🐳 WordPress Hardened en Docker",
		description:
			"Stack de producción WordPress + MySQL desplegado con Docker Compose. Implementa Docker Secrets, healthchecks, prefijo de tablas personalizado, imágenes con tags fijos y volúmenes nombrados.",
		tags: ["Docker", "WordPress", "MySQL", "Security", "DevOps"],
		link: "/guias/docker-compose-produccion/",
		status: "Completado",
	},
	{
		title: "🔥 Configuración de Firewall pfSense",
		description:
			"Configuración profesional de pfSense con tres interfaces (WAN, LAN, DMZ), reglas de firewall jerárquicas, NAT/Port Forwarding y políticas de seguridad por zona.",
		tags: ["pfSense", "Firewall", "Networking", "NAT", "Security"],
		link: "/guias/pfsense-firewall/",
		status: "Completado",
	},
	{
		title: "🛡️ Monitorización con Wazuh SIEM",
		description:
			"Despliegue y configuración de Wazuh como sistema SIEM para la detección de amenazas, monitorización de integridad de ficheros y respuesta a incidentes en la infraestructura de red.",
		tags: ["Wazuh", "SIEM", "Security", "Monitoring", "Ubuntu"],
		link: "/guias/wazuh-siem/",
		status: "En desarrollo",
	},
	{
		title: "🌐 Portfolio Personal (Este sitio)",
		description:
			"Sitio web personal construido con Astro, combinando el tema Cactus para el blog y portfolio con Starlight para la documentación técnica. Desplegado en GitHub Pages.",
		tags: ["Astro", "Starlight", "GitHub Pages", "Tailwind CSS"],
		link: "https://github.com/Pabloceda/pabloceda.github.io",
		status: "En desarrollo",
	},
];
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">Proyectos</h1>
	<p class="mb-12 text-sm">
		Proyectos realizados durante el ciclo formativo de Administración de Sistemas Informáticos en
		Red (ASIR). Cada proyecto incluye documentación técnica detallada.
	</p>
	<div class="space-y-8">
		{
			projects.map((project) => (
				<article class="border-accent/30 rounded-md border p-5 transition-all hover:border-accent">
					<div class="mb-2 flex flex-wrap items-center gap-2">
						<h2 class="text-lg font-semibold">
							<a class="cactus-link" href={project.link}>
								{project.title}
							</a>
						</h2>
						<span
							class={`rounded-full px-2 py-0.5 text-xs font-medium ${
								project.status === "Completado"
									? "bg-green-500/10 text-green-500"
									: "bg-yellow-500/10 text-yellow-500"
							}`}
						>
							{project.status}
						</span>
					</div>
					<p class="mb-3 text-sm">{project.description}</p>
					<div class="flex flex-wrap gap-1.5">
						{project.tags.map((tag) => (
							<span class="bg-accent/10 text-accent rounded-md px-2 py-0.5 text-xs">{tag}</span>
						))}
					</div>
				</article>
			))
		}
	</div>
</PageLayout>
